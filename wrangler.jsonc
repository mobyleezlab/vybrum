{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vybrum",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "dist/server/index.mjs",
  "no_bundle": true,
  "rules": [
    { "type": "ESModule", "globs": ["**/*.mjs", "**/*.js"] }
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist/client"
  },
}
